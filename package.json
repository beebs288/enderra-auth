{
  "name": "@enderra/auth",
  "version": "0.3.1",
  "description": "Enderra suite auth contract + provider adapters",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json && node -e \"import('./dist/index.js').then(m => { if (!m.SupabaseAuthAdapter || !m.createEnderraAuth) process.exit(1) })\"",
    "prepare": "tsc -p tsconfig.json",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "peerDependencies": {
    "@supabase/supabase-js": "^2.108.0"
  },
  "devDependencies": {
    "@supabase/supabase-js": "^2.108.2",
    "typescript": "~5.6.0",
    "vitest": "^4.1.8"
  },
  "license": "UNLICENSED"
}
